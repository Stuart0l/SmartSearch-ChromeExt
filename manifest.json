{
  "manifest_version": 3,
  "name": "Smart Search Router",
  "short_name": "Smart Search",
  "version": "1.0.0",
  "description": "Automatically routes your searches to Google or Baidu based on real-time network accessibility. Perfect for users in regions where Google availability varies.",
  "author": "Stuart Luo",
  "homepage_url": "https://github.com/Stuart0l/SmartSearch-ChromeExt",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "*://smartsearch.local/*",
    "https://www.google.com/generate_204"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
